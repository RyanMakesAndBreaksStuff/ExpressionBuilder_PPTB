{
  "name": "@ryanmakes/eb_builder-ui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b && node -e \"require('fs').mkdirSync('dist/theme', { recursive: true }); require('fs').copyFileSync('src/theme/tokens.css', 'dist/theme/tokens.css');\"",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@ryanmakes/eb_engine": "file:../engine",
    "@ryanmakes/eb_platformadapter": "file:../platform",
    "@fluentui/react-components": "9.74.1",
    "@fluentui/react-icons": "^2.0.330",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "vitest": "^4.1.8"
  }
}
